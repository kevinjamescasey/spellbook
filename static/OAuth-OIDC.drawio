        <mxCell id="r1faT7FxPUF7NRqCv4MH-4" parent="1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;rotation=-90;dashed=1;size=0.3759146719583275;" value="" vertex="1">
