        <mxCell id="2tNkJyg_PnT1xpnZROH5-26" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=1;points=[];autosize=0;fillColor=#dae8fc;strokeColor=#6c8ebf;recursiveResize=1;whiteSpace=wrap;" value="OAuth does not describe how the session between the user-agent and confidential client is maintained, but for the web application client profile it says the resource owner does not have access to the access token. So the confidential client would need to exchange some session token with the user-agent to maintain a session and avoid having to re-authenticate for each request" vertex="1">
