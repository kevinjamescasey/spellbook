        <mxCell id="WJbr3lGSmRQPrJS-flyF-57" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;" value="&lt;div&gt;References:&lt;/div&gt;https://auth0.com/docs/authorization/which-oauth-2-0-flow-should-i-use&lt;br&gt;https://auth0.com/docs/flows&lt;br&gt;&lt;br&gt;https://oauth.net/2/grant-types/&lt;br&gt;https://oauth.net/2/client-types/&lt;br&gt;https://oauth.net/2/scope/&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;https://aaronparecki.com/oauth-2-simplified/&lt;br&gt;&lt;br&gt;https://www.npmjs.com/package/express-session#compatible-session-stores&lt;/div&gt;" vertex="1">
