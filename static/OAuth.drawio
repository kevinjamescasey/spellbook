        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-101" value="OAuth does not describe how the session between the user-agent and confidential client is maintained, but for the web application client profile it says the resource owner does not have access to the access token. So the confidential client would need to exchange some session token with the user-agent to maintain a session and avoid having to re-authenticate for each request" style="text;html=1;align=center;verticalAlign=middle;resizable=1;points=[];autosize=0;fillColor=#dae8fc;strokeColor=#6c8ebf;recursiveResize=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1405.23" y="288.84000000000003" width="238" height="137.16" as="geometry" />
        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-102" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="1393.23" y="57" width="657.37" height="150" as="geometry" />
        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-103" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.199;entryY=1.011;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="TRt596Y1K884QViLiuUj-101" target="TRt596Y1K884QViLiuUj-102">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-104" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="-106.76999999999998" y="-274" width="517.54" height="273" as="geometry" />
        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-105" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.998;entryY=0.844;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="TRt596Y1K884QViLiuUj-79" target="TRt596Y1K884QViLiuUj-102">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-106" value="ensures redirect URI and client id combination given in authz request &lt;br&gt;matches previously registered combination" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="540.23" y="300" width="384" height="41" as="geometry" />
