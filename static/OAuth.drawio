        <mxCell id="TRt596Y1K884QViLiuUj-107" value="JWT: JSON Web Tokens&amp;nbsp;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="2018.23" y="973" width="208" height="32" as="geometry" />
        </mxCell>
        <mxCell id="TRt596Y1K884QViLiuUj-108" value="JWTs can be verified by checking their signature with a public key that is fetched seldomly form a JWKS endpoint on the auth server so there is no need to send each token to the auth server." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="2041.23" y="1012" width="319" height="112" as="geometry" />
        </mxCell>
